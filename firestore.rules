rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - email: string (required) - User's email address
    //   - role: string (required, 'admin' or 'user') - User's role
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: dashboards
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - subtitle: string (required, < 100 chars)
    //   - desc: string (required, < 500 chars)
    //   - url: string (required, valid URL)
    //   - image: string (required, valid URL or path)
    //   - thumb: string (required, valid URL or path)
    //   - order: number (required)
    //   - createdAt: timestamp (required, immutable)
    //   - authorUid: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "baongoc.nguyen.data@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('authorUid' in request.resource.data) || request.resource.data.authorUid == request.auth.uid;
    }

    function uidNotModified() {
      return !('authorUid' in request.resource.data) || request.resource.data.authorUid == resource.data.authorUid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^/.*") || url.matches("^data:image/.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'role', 'createdAt']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    function isValidDashboard(data) {
      return hasOnlyAllowedFields(['title', 'subtitle', 'desc', 'url', 'image', 'thumb', 'order', 'createdAt', 'authorUid']) &&
             validStringLength('title', 1, 500) &&
             validStringLength('subtitle', 1, 500) &&
             validStringLength('desc', 1, 5000) &&
             isValidUrl(data.url) &&
             isValidUrl(data.image) &&
             isValidUrl(data.thumb) &&
             data.order is number &&
             data.createdAt is timestamp &&
             data.authorUid is string && data.authorUid.size() > 0 && data.authorUid.size() < 50;
    }

    function isValidStoreDashboard(data) {
      return hasOnlyAllowedFields(['title', 'category', 'desc', 'url', 'image', 'price', 'paymentLink', 'order', 'createdAt', 'authorUid']) &&
             validStringLength('title', 1, 500) &&
             validStringLength('category', 1, 500) &&
             validStringLength('desc', 1, 5000) &&
             (data.url == '' || isValidUrl(data.url)) &&
             isValidUrl(data.image) &&
             validStringLength('price', 1, 100) &&
             (data.paymentLink == '' || isValidUrl(data.paymentLink)) &&
             data.order is number &&
             data.createdAt is timestamp &&
             data.authorUid is string && data.authorUid.size() > 0 && data.authorUid.size() < 50;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.createdAt == resource.data.createdAt) || isAdmin());
      allow delete: if isAdmin();
    }

    match /dashboards/{dashboardId} {
      allow read: if true;
      allow create: if isAdmin() && isValidDashboard(request.resource.data) && uidUnchanged();
      allow update: if isAdmin() && isValidDashboard(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /store_dashboards/{dashboardId} {
      allow read: if true;
      allow create: if isAdmin() && isValidStoreDashboard(request.resource.data) && uidUnchanged();
      allow update: if isAdmin() && isValidStoreDashboard(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
  }
}
